{
  "manifest_version": 3,
  "name": "cdut-wqhelper",
  "version": "2.0",
  "description": "成都理工大学问渠学堂助手 — 课件PPT导出/课堂笔记提取/课程列表",
  "author": "chenzy0355@gmail.com",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://classroom.wqxt.cdut.edu.cn/*",
    "*://video.wqxt.cdut.edu.cn/*",
    "*://yjapi.wqxt.cdut.edu.cn/*",
    "*://education.wqxt.cdut.edu.cn/*",
    "*://wqxt.cdut.edu.cn/*"
  ],
  "action": {
    "default_title": "提取课件"
  },
  "background": {
    "service_worker": "background.js"
  }
}